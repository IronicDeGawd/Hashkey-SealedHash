# HashKey Chain testnet deployer. Never commit real PRIVATE_KEY values.
PRIVATE_KEY=0x
RPC_URL_TESTNET=https://testnet.hsk.xyz
RPC_URL_MAINNET=https://mainnet.hsk.xyz

# Deployed HashKey KYC SBT addresses (verified on-chain 2026-04-14).
# Leave KYC_SBT_ADDRESS blank to deploy a self-contained MockKycSBT for demos.
# Set it to the live address below to wire the auction into production KYC.
KYC_SBT_ADDRESS=
# KYC_SBT_ADDRESS=0xA45f42F09A7Ae50e556467cf65cF3Cf45711114E  # testnet
# KYC_SBT_ADDRESS=0x0f362c05fb3Fadca687648F412abE2A6d6450D70  # mainnet

# Minimum KYC level the auction enforces. 1 BASIC, 2 ADVANCED, 3 PREMIUM, 4 ULTIMATE.
MIN_KYC_LEVEL=1

# Populated after running Deploy.s.sol (verifier + kyc + auction) and
# DeployMockAssets.s.sol (mRWA + mUSDT). SeedDemoAuction.s.sol reads these.
VERIFIER_ADDRESS=
MOCK_KYC_ADDRESS=
AUCTION_ADDRESS=
MOCK_RWA_ADDRESS=
MOCK_USDT_ADDRESS=
