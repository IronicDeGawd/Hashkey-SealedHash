# Frontend env overrides. Copy to .env.local and edit as needed.
# The frontend has hard-coded defaults that match the live HashKey testnet
# deployment so all of these are optional.

NEXT_PUBLIC_HASHKEY_RPC_URL=https://testnet.hsk.xyz
NEXT_PUBLIC_VERIFIER_ADDRESS=0x9E0830b0D6f180e2Eaf8E14956386383d855cEd7
NEXT_PUBLIC_KYC_SBT_ADDRESS=0x53e1F063166AbFbc7C387839BA439b1bb974E319
NEXT_PUBLIC_AUCTION_ADDRESS=0x15dd37d92eD9526300FE5de5aB555AeA6C621f22
NEXT_PUBLIC_MOCK_RWA_ADDRESS=0x6d4b1af928CBE669659521B5DEA37961B37ACCe9
NEXT_PUBLIC_MOCK_USDT_ADDRESS=0xAfc441e6baf4518f38159AecBd0Eed6EDd083198

# --- Off-chain backend (v2) -------------------------------------------------
# Server-side only. Do NOT prefix with NEXT_PUBLIC_ — these must never reach
# the browser. In production these live in /etc/sealedhash/env (chmod 600)
# and are loaded by PM2 / systemd; locally they go in .env.local.

# Postgres connection. Docker Compose at infra/docker-compose.yml runs
# Postgres bound to 127.0.0.1 only. Generate POSTGRES_PASSWORD with:
#   openssl rand -hex 32
DATABASE_URL=postgres://sealedhash:CHANGE_ME@127.0.0.1:5432/sealedhash

# iron-session cookie encryption key (Phase 3). Must be >= 32 chars.
# Generate with: openssl rand -hex 32
SESSION_PASSWORD=CHANGE_ME_AT_LEAST_32_CHARS_OF_RANDOM_HEX

